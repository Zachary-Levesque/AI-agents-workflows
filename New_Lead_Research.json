        "jsonSchemaExample": "{\n  \"subject\": \"Why Acme is worth watching\",\n  \"body\": \"Acme is a fast-growing company in the industrial robotics market with recent partnerships and expansion activity that make it relevant for outbound outreach.\",\n  \"confidence\": 8,\n  \"needsReview\": false,\n  \"sources\": \"Company site; recent funding article; product launch coverage\"\n}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
