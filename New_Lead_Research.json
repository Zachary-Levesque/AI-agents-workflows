      "name": "Structured Output Parser"
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nif (!output || typeof output !== 'object') {\n  throw new Error('Expected structured output from briefing agent.');\n}\n\nconst Subject = String(output.subject || '').trim();\nconst Body = String(output.body || '').trim();\nconst sources = String(output.sources || '').trim();\nconst confidence = Number(output.confidence ?? 0);\nconst reviewFlag = Boolean(output.needsReview);\nconst needsReview = reviewFlag || !Subject || !Body || confidence < 7 || Body.length < 120;\n\nreturn [\n  {\n    json: {\n      Subject,\n      Body,\n      sources,\n      confidence,\n      needsReview,\n      reviewStatus: needsReview ? 'needs_review' : 'ready'\n    }\n  }\n];\n"
      },
