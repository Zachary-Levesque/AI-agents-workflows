      "id": "c0bbdc20-4012-4a0e-912b-c393ac330202",
      "name": "Structured Output Parser - Contact"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\nconst parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n\nconst name = String(parsed.name || '').trim();\nconst email = String(parsed.email || '').trim();\nconst phoneNumber = String(parsed.phoneNumber || '').trim();\nconst confidence = Number(parsed.confidence ?? 0);\nconst emailIsValid = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\nconst nameIsValid = !!name && name.toLowerCase() !== 'not found';\nconst valid = nameIsValid && emailIsValid && confidence >= 7;\n\nreturn [{\n  json: {\n    name,\n    email,\n    phoneNumber,\n    confidence,\n    validationStatus: valid ? 'valid' : 'invalid'\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2360,
        120
      ],
      "id": "2f6af538-43b1-4131-9984-1cc9bdf93f5b",
      "name": "Ready for Sheet"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.answer }}",
        "options": {
          "systemMessage": "=You are a smart AI parsing assistant. Your task is to extract a person’s contact information from the raw text provided in `{{ $json.answer }}`.\n\nReturn only the structured fields required by the output parser:\n- `name`\n- `email`\n- `phoneNumber`\n- `confidence` as an integer from 1 to 10\n\nRules:\n- If a field is missing, return an empty string for that field.\n- Do not invent private contact data.\n- Use a lower confidence score when the evidence is weak or ambiguous."
        },
        "hasOutputParser": true
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.9,
