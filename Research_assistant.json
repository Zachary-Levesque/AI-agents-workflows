    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phoneNumber\": \"+1 555 555 5555\",\n  \"confidence\": 8\n}"
