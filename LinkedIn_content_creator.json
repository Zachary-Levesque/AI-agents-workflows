        "openAiApi": {
          "id": "p8UCjIalbKhZg8ql",
          "name": "OpenAI Credential"
        }
      }
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"content\": \"AI adoption is no longer a side project. The companies moving fastest are embedding it directly into operations, customer workflows, and decision systems... #AI #Automation\",\n  \"confidence\": 8,\n  \"needsReview\": false,\n  \"sources\": \"Industry adoption trend article; workflow automation article; enterprise AI strategy article\"\n}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [
        760,
        60
      ],
      "id": "5d5a2edf-b4d0-4db0-9d21-3602db780301",
      "name": "Structured Output Parser"
    },
    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nif (!output || typeof output !== 'object') {\n  throw new Error('Expected structured LinkedIn draft output.');\n}\n\nconst content = String(output.content || '').trim();\nconst confidence = Number(output.confidence ?? 0);\nconst sources = String(output.sources || '').trim();\nconst reviewFlag = Boolean(output.needsReview);\nconst needsReview = reviewFlag || !content || confidence < 7;\nconst formattedContent = `${content}\\n\\nSources: ${sources || 'Add source links before publishing.'}`;\n\nreturn [{\n  json: {\n    content: formattedContent,\n    status: needsReview ? 'Needs review' : 'Draft ready for review',\n    confidence,\n    sources\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        860,
        -120
      ],
